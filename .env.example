DISCORD_TOKEN=your_discord_bot_token
PLEX_CLIENT_IDENTIFIER=my-custom-music-bot-id

# --- Web portal ports ---
# Two-layer port mapping: Docker exposes the container's PORT on the host's WEB_PORT.
# In most setups you only need to change WEB_PORT.
#
# PORT      = port the Node process binds inside the container. Should stay 3000
#             unless you also change docker-compose.yml's container-side mapping.
# WEB_PORT  = host port published by Docker. Change this if 3000 is already in use
#             on your host. The installer auto-detects a free port and sets it here.
PORT=3000
WEB_PORT=3000

# Host port mapping for Ollama (only used with --profile ai-enabled).
OLLAMA_PORT=11434

# Logging verbosity: trace | debug | info | warn | error | fatal
# Defaults: debug in dev, info in production. Override here to bump verbosity.
# LOG_LEVEL=info

# Lidarr integration (required for /search commands)
LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=your_lidarr_api_key

# After Auth, these will be populated or passed via DB
# PLEX_TOKEN=
# PLEX_SERVER_URL=

