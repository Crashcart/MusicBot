DISCORD_TOKEN=your_discord_bot_token
PLEX_CLIENT_IDENTIFIER=my-custom-music-bot-id

# Internal port the web portal listens on inside the container.
PORT=3000

# Host port mapping for the web portal. Change if 3000 is already in use on the host.
WEB_PORT=3000

# Host port mapping for Ollama (only used with --profile ai-enabled).
OLLAMA_PORT=11434

# Admin password for the web portal (configuration & log viewer).
# install.sh generates a random value automatically. If left as 'changeme'
# or empty, the portal runs unprotected and shows a banner warning.
ADMIN_PASSWORD=changeme

# Logging verbosity: trace | debug | info | warn | error | fatal
# Defaults: debug in dev, info in production.
# LOG_LEVEL=info

# Lidarr integration (required for /search commands)
LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=your_lidarr_api_key

# After Auth, these will be populated or passed via DB
# PLEX_TOKEN=
# PLEX_SERVER_URL=

